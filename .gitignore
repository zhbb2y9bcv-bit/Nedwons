# Rust
/target
**/target
Cargo.lock.bak
*.rs.bk

# macOS
.DS_Store

# Xcode / Swift
apps/ios/**/build/
apps/ios/**/.build/
apps/ios/**/*.xcuserstate
apps/ios/**/xcuserdata/
apps/ios/**/DerivedData/
apps/ios/**/.swiftpm/
*.xcarchive
*.ipa
*.dSYM.zip
*.dSYM

# MLS UniFFI bridge derived artifacts — large/rebuildable via scripts/build_mls_ffi.sh (ADR-0007).
# The generated Swift (apps/ios/SentinelMLS/Sources/MlsFfi/mls_ffi.swift) IS committed and
# stale-checked in CI; the XCFramework binary + provenance manifest + scratch generation are not.
apps/ios/**/*.xcframework
apps/ios/**/.build-xc/
apps/ios/SentinelMLS/ARTIFACTS.md
core/mls-ffi/generated/

# cargo-fuzz: keep the target + a small seed corpus committed; ignore crash artifacts + coverage.
core/mls-ffi/fuzz/artifacts/
core/mls-ffi/fuzz/coverage/

# Secrets — must never be committed. Real values live in a KMS/secret manager.
*.p8
*.p12
*.mobileprovision
.env
.env.*
!.env.example
secrets/
*.pem
!contracts/**/*.pem  # (none expected; guard against accidental private keys)

# Editor
.idea/
.vscode/
*.swp

# CycloneDX SBOMs (R-501) — generated build artifacts (CI uploads them)
sbom/
**/*.cdx.json

# Generated Xcode app project (xcodegen from apps/ios/Sentinel/project.yml — regenerable)
apps/ios/**/*.xcodeproj
# Auto-grown fuzz corpus (regenerable); the deterministic tests + harness are what matter.
core/mls-ffi/fuzz/corpus/secret_state/
