# Nedwons backend environment template. Copy to `.env` and fill in; NEVER commit real secrets.
# The server reads these at startup; unset optional groups simply disable that feature.

# --- Core ---
DATABASE_URL=postgres://localhost/nedwons_dev
NEDWONS_BIND=0.0.0.0:8097
NEDWONS_RATE_PER_MIN=6000

# --- Stable signing keys (REQUIRED before device testing — see scripts/gen_server_keys.sh) ---
# Without these the server mints EPHEMERAL keys per start, breaking client pinning + the KT audit.
NEDWONS_LOG_SIGNING_KEY=          # 32-byte hex; its public key is pinned in the app
NEDWONS_SENDER_CERT_KEY=          # 32-byte hex; sealed-sender certificate signer

# --- APNs push (#4). Absent ⇒ push disabled. Topic MUST equal the app's bundle id. ---
NEDWONS_APNS_KEY_P8=              # contents of the Apple .p8 (PKCS#8 PEM), verbatim; or _KEY_HEX
NEDWONS_APNS_KEY_ID=             # 10-char key id from the Apple portal
NEDWONS_APNS_TEAM_ID=            # 10-char Apple Team ID
NEDWONS_APNS_TOPIC=app.nedwons.demo
# NEDWONS_APNS_URL=https://api.sandbox.push.apple.com   # sandbox for dev builds

# --- App Attest verification (#10). Absent ⇒ attestations stored unverified (bootstrap). ---
NEDWONS_APP_ATTEST_APP_ID=       # TeamID.bundle-id (e.g. ABCDE12345.app.nedwons.demo)
# NEDWONS_APP_ATTEST_DEV=1        # accept development-environment attestations (never in prod)

# --- Reverse proxy (only behind a trusted proxy that sets this header to the real client IP) ---
# NEDWONS_TRUSTED_IP_HEADER=x-real-client-ip
