<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  App entitlements (least privilege). Wired into the build via project.yml (CODE_SIGN_ENTITLEMENTS).
  These declare the capabilities; the matching App ID + provisioning profile are configured in the
  Apple Developer portal (your side) before a device build will sign.
  - App Attest (#10): appattest-environment (development here; "production" for release).
  - Push (#4): aps-environment; payloads are opaque wake-ups only (PRIVACY.md / PUSH_NOTIFICATIONS.md).
  - Keychain access group (shared with the Notification Service Extension so it can read the same
    session / at-rest root to decrypt): uncomment once the App ID + app group are provisioned; the
    identifier must match the real group.
-->
<plist version="1.0">
<dict>
    <key>aps-environment</key>
    <string>development</string>
    <key>com.apple.developer.devicecheck.appattest-environment</key>
    <string>development</string>
    <!-- Enable once the App ID + Keychain group are provisioned (required for the NSE to decrypt):
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)app.sentinel.shared</string>
    </array>
    -->
</dict>
</plist>
